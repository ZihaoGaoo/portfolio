# The Next app and the agent HTTP service cannot both use port 3000 locally.
# Point this at the Fastify server from mini-agent-ts-lite.
NEXT_PUBLIC_AGENT_API_BASE_URL=http://127.0.0.1:3100

# This must match a key from AGENT_ENVIRONMENT_MAP_JSON in mini-agent-ts-lite.
NEXT_PUBLIC_AGENT_ENVIRONMENT_ID=portfolio
